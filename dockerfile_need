FROM registry.jihulab.com/yincheng/ml/base:torch_cuda_2.3.1 AS torch_builder

FROM mcr.microsoft.com/devcontainers/python:3.10

COPY --from=torch_builder /usr/local/lib/python3.10/site-packages /usr/local/lib/python3.10/site-packages
ENV PYTHONPATH=/usr/local/lib/python3.10/site-packages

# CONFIG APT SOURCE (Debian 13 "trixie")
# 可选：换成清华 Debian 源（devcontainers/python:3.10 使用 /etc/apt/sources.list.d/debian.sources）
RUN set -eux; \
    if [ -f /etc/apt/sources.list.d/debian.sources ]; then \
      sed -i 's|http://deb.debian.org/debian|https://mirrors.tuna.tsinghua.edu.cn/debian|g' /etc/apt/sources.list.d/debian.sources; \
      sed -i 's|http://deb.debian.org/debian-security|https://mirrors.tuna.tsinghua.edu.cn/debian-security|g' /etc/apt/sources.list.d/debian.sources; \
    fi

# 安装基础工具
RUN set -eux; \
    apt-get update -y; \
    apt-get install -y --no-install-recommends \
      git \
      libx11-xcb1 \
      libgl1 \
      imagemagick \
      tmux; \
    rm -rf /var/lib/apt/lists/*

ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# CLARIFY VERSION: PIP=25.0.1, SETUPTOOLS=58.0.4
RUN rm -rf /usr/local/lib/python3.10/site-packages/pip* \
    && rm -rf /usr/local/lib/python3.10/site-packages/setuptools* \
    && python3 -m ensurepip --default-pip \
    && python3 -m pip install --upgrade pip==25.0.1 --no-cache-dir \
    && python3 -m pip install setuptools==58.0.4 --no-cache-dir

# Install dependencies from requirements.txt (generated from pyproject.toml)
COPY requirements.txt /tmp/pip-tmp/
RUN pip3 --disable-pip-version-check \
    --no-cache-dir install \
    -i https://mirrors.aliyun.com/pypi/simple/ \
    -r /tmp/pip-tmp/requirements.txt && \
    rm -rf /tmp/pip-tmp

HEALTHCHECK NONE
WORKDIR /workspace
USER vscode
